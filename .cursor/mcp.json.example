{
  "mcpServers": {
    "weight-agent-cos": {
      "type": "stdio",
      "command": "python3",
      "args": ["${workspaceFolder}/mcp/cos-recordings/server.py"],
      "env": {
        "COS_SECRET_ID": "${env:COS_SECRET_ID}",
        "COS_SECRET_KEY": "${env:COS_SECRET_KEY}",
        "COS_REGION": "ap-nanjing",
        "COS_BUCKET": "your-bucket-1250000000",
        "COS_PREFIX": "recordings/"
      }
    }
  }
}
